{
	"openapi": "3.0.0",
	"components": {
		"examples": {},
		"headers": {},
		"parameters": {},
		"requestBodies": {},
		"responses": {},
		"schemas": {
			"ChatTaskResponse": {
				"properties": {
					"taskId": {
						"type": "string"
					},
					"message": {
						"type": "string"
					}
				},
				"required": [
					"taskId",
					"message"
				],
				"type": "object",
				"additionalProperties": false
			},
			"ChatRequest": {
				"properties": {
					"query": {
						"type": "string"
					}
				},
				"required": [
					"query"
				],
				"type": "object",
				"additionalProperties": false
			},
			"ChatStatusResponse": {
				"properties": {
					"status": {
						"type": "string",
						"enum": [
							"queued",
							"processing",
							"completed",
							"failed"
						]
					},
					"displayMessage": {
						"type": "string"
					},
					"result": {}
				},
				"required": [
					"status",
					"displayMessage"
				],
				"type": "object",
				"additionalProperties": false
			}
		},
		"securitySchemes": {}
	},
	"info": {
		"title": "erica-capstone-2026-backend",
		"version": "1.0.0",
		"license": {
			"name": "ISC"
		},
		"contact": {}
	},
	"paths": {
		"/chat": {
			"post": {
				"operationId": "CreateChatTask",
				"responses": {
					"200": {
						"description": "Ok",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/ChatTaskResponse"
								}
							}
						}
					}
				},
				"description": "질문을 전송하고 비동기 처리용 taskId를 발급받는다.",
				"tags": [
					"Chat"
				],
				"security": [],
				"parameters": [],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/ChatRequest"
							}
						}
					}
				}
			}
		},
		"/chat/status/{taskId}": {
			"get": {
				"operationId": "GetChatStatus",
				"responses": {
					"200": {
						"description": "Ok",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/ChatStatusResponse"
								}
							}
						}
					}
				},
				"description": "특정 taskId의 현재 상태를 조회한다.",
				"tags": [
					"Chat"
				],
				"security": [],
				"parameters": [
					{
						"in": "path",
						"name": "taskId",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				]
			}
		}
	},
	"servers": [
		{
			"url": "/api"
		}
	]
}