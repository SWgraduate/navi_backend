{
  "entryFile": "src/index.ts",
  "noImplicitAdditionalProperties": "silently-remove-extras",
  "controllerPathGlobs": [
    "src/controllers/**/*Controller.ts"
  ],
  "spec": {
    "outputDirectory": "src/generated",
    "specVersion": 3,
    "basePath": "/api",
    "securityDefinitions": {
      "sessionAuth": {
        "type": "apiKey",
        "name": "connect.sid",
        "in": "cookie"
      }
    }
  },
  "routes": {
    "authenticationModule": "src/authentication.ts",
    "routesDir": "src/generated",
    "basePath": "/api"
  },
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "src/*": [
        "src/*"
      ]
    }
  }
}